# StockFlow Backend — Environment Variables (copy to .env and fill in)

# Server
PORT=4000
NODE_ENV=development

# Admin
ADMIN_ORG_ID=your_admin_org_id
ADMIN_SECRET=your_admin_secret

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# CORS / Client
CLIENT_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Zoho OAuth (per-org config stored in Supabase — these are fallbacks)
ZOHO_REDIRECT_URI=http://localhost:4000/callback/zoho
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_BOOKS_API_URL=https://www.zohoapis.com/books/v3

# PayFast
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
