# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json  # Path to Firebase service account JSON file
FIREBASE_DATABASE_URL=https://<your-project-id>.firebaseio.com  # Firebase Realtime Database URL

# Server Configuration
PORT=4000  # Port number for the Express server
NODE_ENV=development  # Environment mode (development, production)

# Admin Configuration
ADMIN_ORG_ID=<seed-admin-org-if-needed>  # Default organization ID for admin operations