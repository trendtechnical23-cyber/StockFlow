## Backend Service Environment Variables (copy to .env and fill in)
PORT=3001
CORS_ORIGINS=http://localhost:3001
SERVER_URL=http://localhost:3001
CLIENT_URL=http://localhost:3001

# Firebase Admin (choose one approach)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
# Or inline JSON (escaped)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# PayFast
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase

# Zoho OAuth
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret

# Frontend API Configuration (Vite)
# Ngrok backend URL - Update this with your actual ngrok URL
# Get the URL by running: ngrok http 4000
# Example: VITE_API_BASE_URL=https://abc123.ngrok-free.app
VITE_API_BASE_URL=

# Alternative: Use local network IP if only accessing within LAN
# VITE_API_BASE_URL=http://192.168.101.111:4000
ZOHO_REDIRECT_URI=http://localhost:3001/callback/zoho
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_BOOKS_BASE=https://www.zohoapis.com/books/v3

# Security / Misc
NODE_ENV=development
LOG_LEVEL=info
