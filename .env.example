## StockFlow Environment Variables (copy to .env and fill in)

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3001
CLIENT_URL=http://localhost:3001
SERVER_URL=http://localhost:4000

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend only — never expose to frontend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Railway backend URL (used by frontend)
VITE_API_BASE_URL=https://your-service.up.railway.app

# Frontend URL — Zoho redirects here after OAuth (no Railway relay hop needed)
VITE_FRONTEND_URL=https://your-app.vercel.app

# Zoho OAuth
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=https://your-app.vercel.app/callback/zoho
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_BOOKS_API_URL=https://www.zohoapis.com/books/v3

# PayFast (South African payments)
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase

# AI
VITE_OPENROUTER_API_KEY=your_openrouter_key
GEMINI_API_KEY=your_gemini_key
